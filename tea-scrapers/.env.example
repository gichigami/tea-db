# tea-scrapers environment configuration.
# Copy this file to `.env` and fill in secrets. `.env` is gitignored.
# Spec reference: specs/tea_scrapers_v1_spec.md §4 (Settings).

# Postgres connection string used by the loader + alembic.
# DATABASE_URL=postgresql+psycopg://localhost/tea

# Root directory for raw JSONL output. Hive-partitioned under this path.
# RAW_DATA_DIR=data/raw

# Reddit API credentials (PRAW). Required for `tea-scrape ingest reddit`.
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=tea-rec-engine/0.1 (contact: gary@...)

# User-Agent header sent on all outbound HTTP. Identifies the project to
# vendors per polite-scraping convention.
# USER_AGENT=tea-rec-engine/0.1 (https://github.com/gary/tea; contact: gary@...)

# structlog level: DEBUG / INFO / WARNING / ERROR.
# LOG_LEVEL=INFO

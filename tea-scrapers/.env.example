# tea-scrapers environment configuration.
# Copy this file to `.env` and fill in secrets. `.env` is gitignored.
# Spec reference: specs/tea_scrapers_v1_spec.md §4 (Settings).

# Postgres connection string used by the loader + alembic.
# DATABASE_URL=postgresql+psycopg://localhost/tea

# Root directory for raw JSONL output. Hive-partitioned under this path.
# RAW_DATA_DIR=data/raw

# Reddit API credentials (PRAW). Required for `tea-scrape ingest reddit`.
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REQUIRED. The default in src/tea_scrapers/config.py is a placeholder
# that's rejected by the Settings validator at startup (spec §12).
REDDIT_USER_AGENT=tea-db-scraper/0.1 (https://github.com/gichigami/tea-db; contact: gjohnson@pioneer-aero.com)

# REQUIRED. User-Agent header on all outbound HTTP. The default in
# src/tea_scrapers/config.py is a placeholder that's rejected by the
# Settings validator at startup — Cloudflare flags placeholder UAs and the
# step-4 smoke test caught 403s on 3 of 4 Shopify vendors as a result. See
# specs/tea_scrapers_v1_spec.md §12 (Shopify storefront bot mitigation).
USER_AGENT=tea-db-scraper/0.1 (https://github.com/gichigami/tea-db; contact: gjohnson@pioneer-aero.com)

# structlog level: DEBUG / INFO / WARNING / ERROR.
# LOG_LEVEL=INFO
